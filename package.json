{
  "name": "site-10-layer-check-pages",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "vue-tsc -b",
    "lint": "eslint .",
    "format": "prettier . --check",
    "format:write": "prettier . --write",
    "story": "histoire dev",
    "test:stories": "histoire build",
    "test:visual": "playwright test",
    "deploy:pages": "wrangler pages deploy dist --project-name site-10-layer-check"
  },
  "dependencies": {
    "@pinia/colada": "^1.3.1",
    "@vue-flow/core": "^1.48.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@histoire/plugin-vue": "^1.0.0-beta.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "histoire": "^1.0.0-beta.1",
    "msw": "^2.14.6",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.3.3",
    "vue-tsc": "^3.2.8",
    "wrangler": "^4.95.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
